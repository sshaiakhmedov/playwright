{
  "name": "playwright",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "directories": {
    "test": "tests"
  },
  "dependencies": {
    "@playwright/test": "1.52.0",
    "allure-commandline": "^2.13.8",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@stylistic/eslint-plugin": "^2.13.0",
    "allure-playwright": "^2.0.0-beta.13",
    "eslint": "^8.57.1",
    "eslint-plugin-playwright": "^2.10.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2"
  },
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test tests/ui",
